    "industrial",
    "automation",
    "subscription",
    "plc"
  ],
  "author": "Industrial Automation Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.13",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@types/ws": "^8.5.0"
  },
  "optionalDependencies": {
    "ws": "^8.14.0"
  },
  "peerDependencies": {
    "ws": "^8.14.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
