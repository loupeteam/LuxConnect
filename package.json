{
  "name": "lux-opcua",
  "version": "1.0.0",
  "description": "Modern TypeScript OPC UA client library with subscription-based value mirroring",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "demo": "node scripts/serve-demo.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:node": "vitest run --project node",
    "test:integration": "vitest run tests/node/integration.node.test.ts",
    "test:integration:watch": "vitest watch tests/node/integration.node.test.ts",
    "test:integration:simple": "vitest run tests/node/integration-simple.node.test.ts",
    "test:integration:opcua": "cross-env TEST_PORT=3001 TEST_PROTOCOL=http vitest run tests/node/integration.node.test.ts",
    "test:integration:opcua:watch": "cross-env TEST_PORT=3001 TEST_PROTOCOL=http vitest watch tests/node/integration.node.test.ts",
    "test:browser": "node scripts/serve-browser-tests.js",
    "test:browser:open": "start http://localhost:8080 && node scripts/serve-browser-tests.js",
    "test:validate": "node scripts/validate-browser-tests.js",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:debug": "vitest --run --no-coverage --reporter=verbose",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "nodedemo": "node examples/nodejs-demo.js",
    "clean": "rimraf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "opcua",
    "typescript",
    "industrial",
    "automation",
    "subscription",
    "plc"
  ],
  "author": "Industrial Automation Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.13",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "playwright": "^1.55.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@loupeteam/loupe-ux": "^2.0.4",
    "@types/ws": "^8.5.0"
  },
  "optionalDependencies": {
    "ws": "^8.18.3"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
