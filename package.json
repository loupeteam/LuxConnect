{
  "name": "@loupeteam/lux-connect",
  "version": "1.0.0",
  "description": "Modern TypeScript OPC UA client library with subscription-based value mirroring",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/loupeteam/LuxConnect.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "prebuild": "node scripts/generate-build-info.js",
    "build": "tsc",
    "predev": "node scripts/generate-build-info.js",
    "dev": "tsc --watch",
    "demo": "node scripts/serve-demo.js",
    "test": "vitest",
    "test:node": "vitest run --project node",
    "test:integration": "vitest run tests/node/integration.node.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:debug": "vitest --run --no-coverage --reporter=verbose",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "clean": "rimraf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "opcua",
    "typescript",
    "industrial",
    "automation",
    "subscription",
    "plc"
  ],
  "author": "Industrial Automation Team",
  "license": "MIT",
  "devDependencies": {
    "@loupeteam/loupe-ux": "^2.0.4",
    "@types/node": "^20.19.13",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "playwright": "^1.55.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "ws": "^8.18.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
