{
  "name": "lux-opcua",
  "version": "1.0.0",
  "description": "Modern TypeScript OPC UA client library with subscription-based value mirroring",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test dist/test/*.js",
    "demo": "node examples/demo.js",
    "clean": "rimraf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "opcua",
